{
  "name": "@clawsuite/workspace-daemon",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "workspace-daemon": "./bin/cli.ts"
  },
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:better-sqlite3",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "cli": "tsx bin/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}